# Copy to .env (git-ignored) for scripts/refresh_and_deploy.sh and local cron.
#
# Option A — paste a fresh Kiosk connection string (expires ~24h):
# AUDIT_DB_CS='Server=...;Database=service-aira;User Id=KioskTemp_...;Password=...'
#
# Option B — auto-fetch SQL creds each run (recommended for cron):
# KIOSK_BEARER_TOKEN='eyJ...'   # kiosk-ui.frontiersin.org → DevTools → Authorization header
#
# Optional — bake manufactured-article flags into the snapshot:
# AUDIT_TABLE_CONN='DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...'
